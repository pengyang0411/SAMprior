df_2 <- rnorm(50, 0, 3);
df_3 <- rnorm(60, 0, 3);
dat <- data.frame(study = c(1,2,3),
n = c(40, 50, 60),
mean = round(c(mean(df_1), mean(df_2), mean(df_3)), 3),
se = round(c(std(df_1), std(df_2), std(df_3)), 3))
